# Copy this file to ".env" in the same folder (backend/), then edit values.
# PowerShell: Copy-Item .env.example .env
# CMD:        copy .env.example .env

# MongoDB — local:
MONGODB_URI=mongodb://127.0.0.1:27017/hrms
# Or MongoDB Atlas (replace user, pass, cluster, db):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/hrms?retryWrites=true&w=majority

# JWT — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

PORT=5000
NODE_ENV=development

# Comma-separated allowed frontend origins
CLIENT_URL=http://localhost:5173

# Optional seed overrides (npm run seed)
# SEED_ADMIN_EMAIL=admin@hrms.demo
# SEED_ADMIN_PASSWORD=Admin@123
# SEED_EMPLOYEE_PASSWORD=Employee@123
# Primary owner admin (created on first seed; password reset on every seed)
# SEED_OWNER_EMAIL=rajan@gmail.com
# SEED_OWNER_PASSWORD=Rajan@123
